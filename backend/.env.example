# Django settings
SECRET_KEY=your-secret-key-here-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,earnova.cloud

# Database - PostgreSQL connection URL
# For local development: postgres://user:password@localhost:5432/earnova
# For Neon/Render: paste the full connection string they give you
DATABASE_URL=postgres://user:password@localhost:5432/earnova

# Firebase - Path to your Firebase service account JSON file
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# Frontend URL (for CORS)
FRONTEND_URL=https://earnova.cloud
